# Copy to .env and fill in. docker-compose reads this file automatically.

# Django settings — required.
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string

# Path on the *host* to the shared inventory SQLite. The dashboard
# reads this read/write because pipeline runs write to its own
# pipeline_log table. Default for a typical Seefmed dev box:
UPSTREAM_DB_PATH=/home/seefmed/healthcare-inventory-management/backend/db.sqlite3

# Optional — flip these to "0" if you want to disable in a particular
# environment. Defaults shown.
# DASHBOARD_REQUIRE_AUTH=1
# DASHBOARD_PERF_LOG=1
# GUNICORN_WORKERS=3
